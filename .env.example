# Copy to .env and fill in your values. .env is gitignored.

# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# LangSmith (free tier) — https://smith.langchain.com/
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-engineer-study

# Ollama base URL — defaults to http://localhost:11434/v1 (local, no API key required)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Postgres + pgvector — sobe com `docker compose up -d`
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_engineer_study
